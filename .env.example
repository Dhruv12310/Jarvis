# Jarvis configuration (Phase 0). Copy to .env to override; .env is git-ignored.
# Every value is optional: the lines below show the built-in defaults.

# Local LLM (Ollama) model tag used for chat generation.
JARVIS_LLM_MODEL=qwen3:14b

# Local embedding model tag (Ollama) for vector similarity.
JARVIS_EMBED_MODEL=nomic-embed-text

# Ollama HTTP endpoint.
JARVIS_OLLAMA_HOST=http://localhost:11434

# Data locations (default under ./data/, git-ignored). Uncomment to relocate.
# JARVIS_DB_PATH=./data/jarvis.db
# JARVIS_VECTOR_DIR=./data/chroma

# --- Phase 1: public-data connectors (keys optional; empty = that connector reports "no key") ---
# Markets (Finnhub free tier): https://finnhub.io/
JARVIS_FINNHUB_API_KEY=
# News (GNews free tier): https://gnews.io/
JARVIS_GNEWS_API_KEY=
# Market watchlist for "what moved today" (comma-separated tickers).
# JARVIS_MARKET_WATCHLIST=AAPL,MSFT,NVDA,GOOGL,AMZN,META,TSLA
# Per-connector cache TTLs in seconds.
# JARVIS_CACHE_TTL_MARKETS=60
# JARVIS_CACHE_TTL_NEWS=300
# JARVIS_CACHE_TTL_HN=300
