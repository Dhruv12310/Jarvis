# Jarvis configuration — copy to .env to override (.env is git-ignored).
#
#   cp .env.example .env      (do this on a FRESH setup; it will overwrite an existing .env)
#
# EVERY value is optional: the lines below show the built-in defaults from jarvis/config.py.
# Secrets are blank by design — an empty key means that connector reports "no key" and never
# fetches (it never invents data). Uncomment + fill only what you actually use.
# Trust boundary: nothing here causes private data to leave the machine. Only the Collectors
# (public data) and Plaid (your opt-in financial source) make outbound calls.

# ============================================================================
# Phase 0 — Brain: local LLM + stores
# ============================================================================
# Local LLM (Ollama) model tag used for chat generation.
JARVIS_LLM_MODEL=qwen3:14b
# Local embedding model tag (Ollama) for vector similarity.
JARVIS_EMBED_MODEL=nomic-embed-text
# Ollama HTTP endpoint. On an always-on Heartbeat machine with no GPU, point this at the Brain
# rig's Ollama over Tailscale, e.g. http://100.113.113.43:11434
JARVIS_OLLAMA_HOST=http://localhost:11434
# Data locations (default under ./data/, git-ignored). Uncomment to relocate.
# JARVIS_DB_PATH=./data/jarvis.db
# JARVIS_VECTOR_DIR=./data/chroma

# ============================================================================
# Tier 2 — Cloud LLM escalation (Anthropic)  (SECRET — the controlled exception)
# ============================================================================
# Empty = local-only, no cloud. Used ONLY for cloud escalation (hard reasoning / large context /
# explicit ask), after PII stripping at the Model Router. Key: https://console.anthropic.com/
# Wired in: with a key set, the company "Deep Dive" (Tier 2) is enabled; empty = it stays disabled.
ANTHROPIC_API_KEY=
# Cloud model for escalation (default claude-sonnet-4-6; claude-opus-4-8 for deeper, costlier runs).
# JARVIS_CLOUD_MODEL=claude-sonnet-4-6

# ============================================================================
# Phase 1 — Knowledge: public-data connectors  (SECRETS — sign up, paste keys)
# ============================================================================
# Markets (Finnhub free tier): https://finnhub.io/
JARVIS_FINNHUB_API_KEY=
# News (GNews free tier): https://gnews.io/
JARVIS_GNEWS_API_KEY=
# Global news also comes from GDELT (keyless worldwide firehose) - no key needed; it runs alongside
# GNews. GDELT updates ~every 15 min and rate-limits bursts, so it is cached for that long.
# JARVIS_CACHE_TTL_GDELT=900
# Market watchlist for "what moved today" (comma-separated tickers).
# JARVIS_MARKET_WATCHLIST=AAPL,MSFT,NVDA,GOOGL,AMZN,META,TSLA
# Per-connector cache TTLs in seconds.
# JARVIS_CACHE_TTL_MARKETS=60
# JARVIS_CACHE_TTL_NEWS=300
# JARVIS_CACHE_TTL_HN=300
# Company fundamentals (profile/financials/analyst/news) change slowly -> cached for an hour.
# JARVIS_CACHE_TTL_FUNDAMENTALS=3600

# ============================================================================
# Phase 2 — Organization: Google Calendar OAuth  (SECRET FILES — paths, not keys)
# ============================================================================
# Download the OAuth client JSON from Google Cloud Console into ./data/, then run
# `python -m jarvis calendar-auth` to mint the user token. Both default under ./data/ (git-ignored).
# JARVIS_GOOGLE_CREDENTIALS=./data/credentials.json
# JARVIS_GOOGLE_TOKEN=./data/token.json

# ============================================================================
# Phase 3 — Voice (local on the Brain; models, not secrets)
# ============================================================================
# STT auto-downloads from HuggingFace; drop to small/base for lower latency.
# JARVIS_STT_MODEL=large-v3-turbo
# Piper voice file you download into ./data/piper/ (git-ignored). Without it, voice is STT-only.
# JARVIS_TTS_MODEL=./data/piper/en_US-lessac-high.onnx

# ============================================================================
# Phase 4 — Finance: Plaid (US, free Sandbox)  (SECRETS — opt-in outbound source)
# ============================================================================
# Empty = Plaid disabled (local CSV/OFX import is the default path). Sign up: https://plaid.com/
# JARVIS_PLAID_CLIENT_ID=
# JARVIS_PLAID_SECRET=
# Minted via the Plaid Link flow once you connect an institution.
# JARVIS_PLAID_ACCESS_TOKEN=
# One of: sandbox | development | production.
# JARVIS_PLAID_ENV=sandbox

# ============================================================================
# Web cockpit — `python -m jarvis serve`  (the 4th front-end)
# ============================================================================
# Bind address: defaults to localhost only. Set to your Tailscale IP or 0.0.0.0 to reach the
# cockpit from another device on the private mesh.
# JARVIS_API_HOST=127.0.0.1
# JARVIS_API_PORT=8765
# Shared secret guarding every /api route. REQUIRED in practice for any off-localhost bind —
# without it those routes are unauthenticated on the network. Pick a long random string; then
# open the cockpit once at  http://<host>:<port>/?token=<that string>
# JARVIS_API_TOKEN=

# ============================================================================
# Phase 2/5 — Memory, reflection & proactivity tuning (all have working defaults)
# ============================================================================
# Memory retrieval (Core §7.1): candidate pool, recency decay (per hour), MMR weights.
# JARVIS_MEMORY_POOL=20
# JARVIS_MEMORY_LAMBDA=0.02
# JARVIS_MEMORY_W_REC=1.0
# JARVIS_MEMORY_W_IMP=1.0
# JARVIS_MEMORY_W_REL=1.0
# Reflection (§7.4): fires when accumulated signal fuel crosses the threshold; confidence rates.
# JARVIS_REFLECTION_THRESHOLD=5.0
# JARVIS_CONFIDENCE_ALPHA=0.3
# JARVIS_CONFIDENCE_GAMMA=0.3
# Candidate-generator horizons (§7).
# JARVIS_URGENCY_HORIZON_HOURS=72
# JARVIS_STALE_GOAL_DAYS=14
# JARVIS_BUDGET_NEAR_FRACTION=0.1
# JARVIS_RECURRING_HORIZON_DAYS=5
# JARVIS_MARKET_MOVE_PCT=3.0
# Usefulness ranker beta weights (§7.2). Threshold is ABSOLUTE+HIGH so silence is the default;
# caps are structural — no score can raise volume.
# JARVIS_BETA_GOAL=1.0
# JARVIS_BETA_URGENCY=1.0
# JARVIS_BETA_INTEREST=1.0
# JARVIS_BETA_TIMING=0.3
# JARVIS_BETA_NOVELTY=0.3
# JARVIS_BETA_FATIGUE=1.0
# JARVIS_USEFULNESS_THRESHOLD=1.0
# Volume caps + DND gate.
# JARVIS_SUGGESTIONS_PER_WINDOW=3
# JARVIS_SUGGESTION_WINDOW_HOURS=24
# JARVIS_PER_CATEGORY_CAP=1
# JARVIS_ENTITY_COOLDOWN_HOURS=48
# JARVIS_NOVELTY_LAMBDA=0.02
# JARVIS_QUIET_HOURS_START=22
# JARVIS_QUIET_HOURS_END=7
# JARVIS_PROACTIVITY_ENABLED=1
# Feedback loop (§7.5/5c): learning rate; per-category dismissal backoff = base * 2^(n-1) days.
# JARVIS_FEEDBACK_LR=0.1
# JARVIS_CATEGORY_COOLDOWN_BASE_DAYS=1
# JARVIS_CATEGORY_COOLDOWN_CAP_DAYS=30
# Scheduler (§6/§9): Heartbeat beat interval (seconds) and the hour (0-23) the daily digest fires.
# JARVIS_DIGEST_HOUR=7
# JARVIS_SCHEDULER_INTERVAL=3600
